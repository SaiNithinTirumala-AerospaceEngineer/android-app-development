<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E">

    <!-- History scroll area -->
    <ScrollView
        android:id="@+id/history_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">
        <TextView
            android:id="@+id/history_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="end"
            android:lineSpacingExtra="4dp"/>
    </ScrollView>

    <!-- Main display -->
    <TextView
        android:id="@+id/display_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="52sp"
        android:gravity="end"
        android:padding="16dp"
        android:maxLines="2"
        android:ellipsize="start"/>

    <!-- Button grid -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical">

        <!-- Row 1: C  +/-  %  ÷ -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="80dp" android:orientation="horizontal">
            <Button android:id="@+id/btn_clear"
                style="@style/CalcBtnGray" android:text="C"/>
            <Button android:id="@+id/btn_sign"
                style="@style/CalcBtnGray" android:text="+/-"/>
            <Button android:id="@+id/btn_percent"
                style="@style/CalcBtnGray" android:text="%"/>
            <Button android:id="@+id/btn_divide"
                style="@style/CalcBtnOrange" android:text="÷"/>
        </LinearLayout>

        <!-- Row 2: 7  8  9  × -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="80dp" android:orientation="horizontal">
            <Button android:id="@+id/btn_7"
                style="@style/CalcBtnDark" android:text="7"/>
            <Button android:id="@+id/btn_8"
                style="@style/CalcBtnDark" android:text="8"/>
            <Button android:id="@+id/btn_9"
                style="@style/CalcBtnDark" android:text="9"/>
            <Button android:id="@+id/btn_multiply"
                style="@style/CalcBtnOrange" android:text="×"/>
        </LinearLayout>

        <!-- Row 3: 4  5  6  - -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="80dp" android:orientation="horizontal">
            <Button android:id="@+id/btn_4"
                style="@style/CalcBtnDark" android:text="4"/>
            <Button android:id="@+id/btn_5"
                style="@style/CalcBtnDark" android:text="5"/>
            <Button android:id="@+id/btn_6"
                style="@style/CalcBtnDark" android:text="6"/>
            <Button android:id="@+id/btn_subtract"
                style="@style/CalcBtnOrange" android:text="−"/>
        </LinearLayout>

        <!-- Row 4: 1  2  3  + -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="80dp" android:orientation="horizontal">
            <Button android:id="@+id/btn_1"
                style="@style/CalcBtnDark" android:text="1"/>
            <Button android:id="@+id/btn_2"
                style="@style/CalcBtnDark" android:text="2"/>
            <Button android:id="@+id/btn_3"
                style="@style/CalcBtnDark" android:text="3"/>
            <Button android:id="@+id/btn_add"
                style="@style/CalcBtnOrange" android:text="+"/>
        </LinearLayout>

        <!-- Row 5: 0(wide)  .  ⌫  = -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="80dp" android:orientation="horizontal">
            <Button android:id="@+id/btn_0"
                style="@style/CalcBtnDark"
                android:layout_weight="2"
                android:text="0"/>
            <Button android:id="@+id/btn_decimal"
                style="@style/CalcBtnDark" android:text="."/>
            <Button android:id="@+id/btn_back"
                style="@style/CalcBtnDark" android:text="⌫"/>
            <Button android:id="@+id/btn_equals"
                style="@style/CalcBtnOrange" android:text="="/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>