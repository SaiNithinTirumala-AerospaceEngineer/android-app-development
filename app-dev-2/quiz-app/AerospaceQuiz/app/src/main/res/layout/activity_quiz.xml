<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:padding="20dp">

    <!-- Header row -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView android:id="@+id/tv_progress"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#8E8E93"
            android:textSize="14sp" android:text="1 / 15"/>
        <TextView android:id="@+id/tv_score"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#0A84FF" android:textSize="14sp"
            android:textStyle="bold" android:text="Score: 0"/>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="8dp"
        android:progressTint="#0A84FF" android:max="15"
        android:layout_marginBottom="16dp"/>

    <!-- Timer -->
    <TextView android:id="@+id/tv_timer"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="20s" android:textSize="20sp" android:textStyle="bold"
        android:textColor="#1C1C1E" android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Question -->
    <TextView android:id="@+id/tv_question"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:textColor="#FFFFFF"
        android:textSize="20sp" android:lineSpacingExtra="6dp"
        android:gravity="center_vertical"/>

    <!-- Option buttons -->
    <Button android:id="@+id/btn_a"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF"
        android:textSize="14sp" android:gravity="start|center_vertical"
        android:paddingStart="16dp" android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/btn_b"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF"
        android:textSize="14sp" android:gravity="start|center_vertical"
        android:paddingStart="16dp" android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/btn_c"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF"
        android:textSize="14sp" android:gravity="start|center_vertical"
        android:paddingStart="16dp" android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/btn_d"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF"
        android:textSize="14sp" android:gravity="start|center_vertical"
        android:paddingStart="16dp" android:layout_marginBottom="16dp"/>

    <!-- Next button -->
    <Button android:id="@+id/btn_next"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="NEXT →" android:textSize="16sp"
        android:textStyle="bold" android:textColor="#FFFFFF"
        android:backgroundTint="#0A84FF"
        android:visibility="gone"/>
</LinearLayout>
