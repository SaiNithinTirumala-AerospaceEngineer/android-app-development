<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1C1C1E">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌡 Temperature Converter"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Type in any field — others update instantly"
        android:textSize="13sp"
        android:textColor="#8E8E93"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Celsius -->
    <TextView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Celsius (°C)"
        android:textColor="#FF9500" android:textSize="14sp"
        android:textStyle="bold" android:layout_marginBottom="6dp"/>
    <EditText android:id="@+id/et_celsius"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:hint="Enter °C" android:inputType="numberDecimal|numberSigned"
        android:textColor="#FFFFFF" android:textColorHint="#636366"
        android:textSize="20sp" android:paddingStart="16dp"
        android:background="#2C2C2E" android:layout_marginBottom="20dp"/>

    <!-- Fahrenheit -->
    <TextView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fahrenheit (°F)"
        android:textColor="#0A84FF" android:textSize="14sp"
        android:textStyle="bold" android:layout_marginBottom="6dp"/>
    <EditText android:id="@+id/et_fahrenheit"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:hint="Enter °F" android:inputType="numberDecimal|numberSigned"
        android:textColor="#FFFFFF" android:textColorHint="#636366"
        android:textSize="20sp" android:paddingStart="16dp"
        android:background="#2C2C2E" android:layout_marginBottom="20dp"/>

    <!-- Kelvin -->
    <TextView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kelvin (K)"
        android:textColor="#34C759" android:textSize="14sp"
        android:textStyle="bold" android:layout_marginBottom="6dp"/>
    <EditText android:id="@+id/et_kelvin"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:hint="Enter K" android:inputType="numberDecimal|numberSigned"
        android:textColor="#FFFFFF" android:textColorHint="#636366"
        android:textSize="20sp" android:paddingStart="16dp"
        android:background="#2C2C2E" android:layout_marginBottom="24dp"/>

    <!-- Status -->
    <TextView android:id="@+id/tv_status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Enter a temperature in any field"
        android:textSize="14sp" android:textColor="#8E8E93"
        android:gravity="center" android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp"/>

    <!-- Clear -->
    <Button android:id="@+id/btn_clear"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="CLEAR ALL" android:textSize="15sp"
        android:textStyle="bold" android:textColor="#1C1C1E"
        android:backgroundTint="#8E8E93"/>

    <!-- Formulas -->
    <TextView android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="°F = (°C × 9/5) + 32   |   K = °C + 273.15"
        android:textSize="11sp" android:textColor="#636366"
        android:gravity="center" android:layout_marginTop="16dp"/>

</LinearLayout>
